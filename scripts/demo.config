# ClinIQ llama-server demo configuration
# Generated from optimization sweep: 2026-04-23
# Winner: combined-best-q3km-nconf (cliniq-gemma4-e2b-Q3_K_M.gguf + no-confidence prompt)
#
# Historical performance (April 14 sweep, 5 runs per case, 5 cases):
#   - Throughput:       1.45 tok/s
#   - Extraction score: 1.00
#   - Valid JSON rate:  100%
# These are the best tok/s AND best quality together — Pareto-optimal winner.

# === Model ===
# Merged fine-tune of Gemma 4 E2B with compact LoRA already applied.
# File is pre-staged at /var/lib/ollama/models/ on talos-jetson-3.
# No separate --lora flag needed (LoRA weights are baked into the GGUF).
MODEL_PATH=/models/cliniq-gemma4-e2b-Q3_K_M.gguf
MODEL_SIZE_GB=2.96

# === llama-server flags ===
CTX_SIZE=2048
N_GPU_LAYERS=99
PARALLEL=1
REASONING_BUDGET=0      # Critical: suppresses thinking tokens that destroy JSON output

# === Client-side params ===
MAX_TOKENS=1024         # Enough for full extraction JSON (complex cases use up to ~700 tokens)
TEMPERATURE=0.1
STREAM=false            # Slightly faster end-to-end than streaming on Jetson

# === System prompt (no-confidence variant; matches `prompt-no-confidence` experiment) ===
SYSTEM_PROMPT="Extract clinical entities from this eICR summary. Output JSON with: patient demographics, conditions (SNOMED/ICD-10), labs (LOINC), medications (RxNorm), vitals, and a case summary. Output valid JSON only."

# === Deployment ===
# Manifest: apps/llama-server/deployment.yaml
# Namespace: gemma4
# Node: talos-jetson-3
# Endpoint: http://192.168.150.41:30083

# === Runner-ups (in case different tradeoffs are wanted) ===
# 1. quant-q3km (no-confidence prompt, 1024 max_tokens):
#    model=cliniq-gemma4-e2b-Q3_K_M.gguf, 1.39 tok/s, score=1.00 (5 runs)
# 2. quant-q4km-baseline:
#    model=cliniq-gemma4-e2b-Q4_K_M.gguf, 1.33 tok/s, score=1.00 (5 runs, 3.2GB more VRAM)
# 3. quant-iq4xs:
#    model=cliniq-gemma4-e2b-IQ4_XS.gguf, 1.29 tok/s, score=1.00 (4 runs)
# 4. reasoning-budget-0 (base + LoRA, Q3_K_M):
#    model=gemma-4-E2B-it-Q3_K_M.gguf + cliniq-compact-lora.gguf, 1.42 tok/s, score=0.85
# 5. nostream-noreasoning-ctx1024 (base + LoRA, ctx=1024):
#    model=gemma-4-E2B-it-Q3_K_M.gguf, 1.44 tok/s, score=1.00 (4 runs) — good for
#    memory-constrained scenarios.
