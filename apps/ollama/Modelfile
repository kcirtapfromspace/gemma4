# Modelfile for fine-tuned Gemma 4 E4B ClinIQ model
# After fine-tuning, upload GGUF to HuggingFace and update the FROM line.
FROM ./gemma4-eicr-fhir-e4b-Q4_K_M.gguf

TEMPLATE """{{- if .System }}{{ .System }}
{{ end }}{{ .Prompt }}"""

SYSTEM """Extract clinical entities from this eICR summary. Output JSON with: patient demographics, conditions (SNOMED/ICD-10), labs (LOINC), medications (RxNorm), vitals, and a case summary. Include confidence scores. Output valid JSON only."""

PARAMETER temperature 0.1
PARAMETER top_p 0.9
PARAMETER num_ctx 2048
PARAMETER stop "</s>"
