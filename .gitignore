data/train.jsonl
data/val.jsonl

# Python
__pycache__/
*.pyc
.venv/

# Model files
*.gguf
*.bin
*.safetensors

# Rust build artifacts
target/
Cargo.lock

# Demo video recordings
demo-video/

# Personal Claude Code settings (contains Obsidian API key etc.)
.claude/settings.local.json
# Local worktrees (Claude Code auto-creates; cumulatively ~2 GB)
.claude/worktrees/

# OS
.DS_Store

# Notebook checkpoints
.ipynb_checkpoints/

# Xcode build artifacts (C13 worktree)
apps/mobile/ios-app/ClinIQ/build/
apps/mobile/ios-app/screenshots-c13/
models/cliniq-gemma4-e2b-v2-Q3_K_M.gguf

# LLVM coverage profiles (build artifact)
*.profraw

# Local Python venv lockfile artifacts left by uv (Python __pycache__
# already covered above)
*.egg-info/

# Generated FHIR Bundles + agent_pipeline trace JSONs (regenerable)
apps/mobile/convert/build/

# Playwright session cache (frontend-eng agent uses this for screenshots)
.playwright-mcp/
# Stray Playwright captures
homepage-test*.png
scripts/.venv/
scripts/_gen_adv7.py

# DuckDB benchmark store (regenerated by scripts/benchmark.py)
*.duckdb
